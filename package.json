{
  "name": "MontmeloInside",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace frontend\" \"npm run dev --workspace backend\"",
    "install-all": "npm install",
    "build": "npm run build --workspace frontend",
    "start:backend": "npm run start --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
